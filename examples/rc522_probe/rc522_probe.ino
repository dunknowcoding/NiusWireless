/*
 * rc522_probe — extended dictionary probe for "unknown" keycards.
 *
 * Tries a much larger dictionary than rc522_recover (Proxmark3's
 * default ~120-key list plus common UID-derived patterns and
 * well-known access-control defaults), reports which keys worked
 * against which sectors, and tests BOTH Key A and Key B.
 *
 * Useful before investing in a full Crypto1 port — many "unknown"
 * cards turn out to have keys that live in the dictionary or follow
 * a vendor pattern. If rc522_probe reaches >75% sectors, you may
 * not need static_nested at all.
 *
 * --- Wiring same as rc522_recover ---
 */

#include <NiusWireless.h>

